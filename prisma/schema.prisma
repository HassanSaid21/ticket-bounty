generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql" 
 
}
// Define your data models here
model Ticket  {
  id String @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  title String
  content String  @db.VarChar(1024)
  status TicketStatus @default(OPEN)
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}